# ============================================
# Upwork n8n Automation - Environment Config
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- n8n Login Credentials ---
N8N_USER=admin
N8N_PASSWORD=admin123

# --- n8n Encryption Key (change this!) ---
N8N_ENCRYPTION_KEY=upwork-auto-key-change-me-to-something-random

# --- Timezone ---
TIMEZONE=Asia/Karachi

# ============================================
# CREDENTIALS YOU WILL CONFIGURE INSIDE n8n UI
# ============================================
# After starting n8n, go to Settings > Credentials
# and add these:
#
# 1. OpenAI API Key
#    - Get from: https://platform.openai.com/api-keys
#
# 2. Gmail / SMTP Email
#    - For Gmail: Enable 2FA, then create App Password
#      https://myaccount.google.com/apppasswords
#    - SMTP Host: smtp.gmail.com
#    - SMTP Port: 465 (SSL) or 587 (TLS)
#    - Username: your-email@gmail.com
#    - Password: your-app-password
#
# 3. Your Upwork RSS Feed URL
#    - Go to Upwork > Find Work > Search your keywords
#    - Look for RSS icon or append /rss to the search URL
#    - Example: https://www.upwork.com/ab/feed/jobs/rss?q=laravel+php&sort=recency
